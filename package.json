{
  "name": "@gilbert_oliveira/commit-wizard",
  "displayName": "Commit Wizard",
  "publisher": "gilbert-oliveira",
  "description": "CLI inteligente para gerar mensagens de commit usando OpenAI",
  "version": "2.0.3",
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "main": "dist-node/commit-wizard.js",
  "type": "module",
  "bin": {
    "commit-wizard": "./bin/commit-wizard.js"
  },
  "scripts": {
    "dev": "node bin/commit-wizard.js",
    "clean": "rm -rf dist-node",
    "build": "npm run clean && npm run build:node",
    "build:node": "tsc --project tsconfig.node.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:report": "jest --coverage && open coverage/lcov-report/index.html",
    "prepublishOnly": "npm run build && npm test",
    "start": "node bin/commit-wizard.js",
    "ci:test": "jest --verbose",
    "ci:build": "npm run build:node",
    "ci:lint": "tsc --noEmit",
    "ci:security": "npm audit",
    "ci:integration": "jest tests/integration.test.ts tests/smart-split.test.ts",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major",
    "check-changes": "node -e \"const { execSync } = require('child_process'); const changed = execSync('git diff --name-only HEAD~1 HEAD', { encoding: 'utf8' }).includes('package.json') || execSync('git diff --name-only HEAD~1 HEAD', { encoding: 'utf8' }).match(/(src|bin|scripts|dist)/\\.*/); console.log(changed ? '🚀 Mudanças detectadas - deploy recomendado!' : '⚠️ Nenhuma mudança significativa detectada'); process.exit(changed ? 0 : 1);\"",
    "type-check": "tsc --noEmit",
    "lint": "eslint --fix .",
    "format": "prettier --write ."
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "openai",
    "cli",
    "automation",
    "conventional-commits"
  ],
  "author": "Gilbert <contato@gilbert.dev.br>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gilbert-oliveira/commit-wizard.git"
  },
  "bugs": {
    "url": "https://github.com/gilbert-oliveira/commit-wizard/issues"
  },
  "homepage": "https://github.com/gilbert-oliveira/commit-wizard#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "dist-node/",
    "README.md",
    "LICENSE",
    ".commit-wizardrc"
  ],
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "clipboardy": "^4.0.0",
    "dotenv": "^17.2.0",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^24.0.13",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "chalk": "^5.3.0",
    "eslint": "^9.30.1",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.1.2",
    "tsx": "^4.20.3",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "preferGlobal": true,
  "publishConfig": {
    "access": "public"
  }
}
