{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "outDir": "dist-node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "lib": ["ES2022"],
    "allowJs": true
  },
  "include": [
    "src/**/*",
    "bin/commit-wizard.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-node",
    "tests"
  ]
} 